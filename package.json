{
  "name": "porra-mundial",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "tsx prisma/deploy-migrations.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:scoring": "tsx prisma/sync-scoring.ts",
    "db:sync-knockout": "tsx prisma/sync-knockout-matches.ts",
    "db:link-football-data": "tsx prisma/link-football-data.ts",
    "db:setup": "prisma migrate dev --name init && tsx prisma/seed.ts && tsx prisma/sync-scoring.ts",
    "vercel-build": "tsx prisma/deploy-migrations.ts && prisma generate && next build"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "html-to-image": "^1.11.13",
    "jose": "^6.2.3",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
